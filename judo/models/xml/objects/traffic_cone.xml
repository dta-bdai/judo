<mujoco model="traffic_cone">
<!-- Copyright (c) 2025 Boston Dynamics AI Institute LLC. All rights reserved. -->
  <body name="traffic_cone" pos="0 0 0">
    <joint name="traffic_cone_joint" type="free"/>

    <!-- Total mass: 7 lbs = 3.175 kg -->
    <!-- Center of mass approximately at 1/3 height of cone = ~0.24m -->
    <!-- Hollow cone: mass concentrated at surface, higher moments of inertia than solid -->
    <!-- For hollow cone, I ≈ (1/2)mr² for radial, (1/4)m(r² + 2h²/3) for axial -->
    <!-- Estimated: Ixx ≈ Iyy ≈ 0.25, Izz ≈ 0.09 -->
    <inertial pos="0 0 0.24" mass="3.175" diaginertia="0.25 0.25 0.09"/>

    <!-- Base plate: 14.5" x 14.5" x 1" (0.3683m x 0.3683m x 0.025m) -->
    <geom name="traffic_cone_base_collision"
          type="box"
          size="0.18415 0.18415 0.0125"
          pos="0 0 0.0125"
          rgba="0.1 0.1 0.1 1.0"
          class="collision"/>
    <geom name="traffic_cone_base_visual"
          type="box"
          size="0.18415 0.18415 0.0125"
          pos="0 0 0.0125"
          rgba="0.1 0.1 0.1 1.0"
          class="visual"/>

    <!-- Cone body approximation: height 28" = 0.7112m, base radius 5.25" = 0.13335m -->
    <!-- Using stacked cylinders to approximate cone shape -->
    <!-- Bottom section -->
    <geom name="traffic_cone_bottom_collision"
          type="cylinder"
          size="0.13335 0.0889"
          pos="0 0 0.1139"
          rgba="1.0 0.4 0.0 1.0"
          class="collision"/>
    <geom name="traffic_cone_bottom_visual"
          type="cylinder"
          size="0.13335 0.0889"
          pos="0 0 0.1139"
          rgba="1.0 0.4 0.0 1.0"
          class="visual"/>

    <!-- Lower-middle section -->
    <geom name="traffic_cone_lower_mid_collision"
          type="cylinder"
          size="0.10 0.0889"
          pos="0 0 0.2917"
          rgba="1.0 0.4 0.0 1.0"
          class="collision"/>
    <geom name="traffic_cone_lower_mid_visual"
          type="cylinder"
          size="0.10 0.0889"
          pos="0 0 0.2917"
          rgba="1.0 0.4 0.0 1.0"
          class="visual"/>

    <!-- Upper-middle section -->
    <geom name="traffic_cone_upper_mid_collision"
          type="cylinder"
          size="0.07 0.0889"
          pos="0 0 0.4695"
          rgba="1.0 0.4 0.0 1.0"
          class="collision"/>
    <geom name="traffic_cone_upper_mid_visual"
          type="cylinder"
          size="0.07 0.0889"
          pos="0 0 0.4695"
          rgba="1.0 0.4 0.0 1.0"
          class="visual"/>

    <!-- Top section -->
    <geom name="traffic_cone_top_collision"
          type="cylinder"
          size="0.02 0.0889"
          pos="0 0 0.6473"
          rgba="1.0 0.4 0.0 1.0"
          class="collision"/>
    <geom name="traffic_cone_top_visual"
          type="cylinder"
          size="0.02 0.0889"
          pos="0 0 0.6473"
          rgba="1.0 0.4 0.0 1.0"
          class="visual"/>

    <site name="trace_traffic_cone" pos="0 0 0" size="0.01"/>
    <site name="site_object" pos="0 0 0.0" size="0.01"/>
  </body>
</mujoco>
